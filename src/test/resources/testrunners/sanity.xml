<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="API Sanity Tests Suite" verbose="3">

    <listeners>
        <listener class-name="com.aventstack.chaintest.plugins.ChainTestListener" />
    </listeners>

    <test name="Grocery Store Orders-RegisterNewClient">
        <classes>
            <class name="com.qa.grocerystoreorders.tests.RegisterNewClientTest"/>
        </classes>
    </test>

    <test name="Grocery Store Orders-Get Orders With OM">
        <classes>
            <class name="com.qa.grocerystoreorders.tests.GetAllOrdersWithObjectMapperTest"/>
        </classes>
    </test>

    <test name="Grocery Store Products-Get API Status">
        <classes>
            <class name="com.qa.grocerystoreproducts.tests.GetAPIStatusTest"/>
        </classes>
    </test>

</suite>